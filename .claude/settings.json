{
  "permissions": {
    "deny": [
      "Read(path:.env)",
      "Read(path:.env.*)",
      "Edit(path:.env)",
      "Edit(path:.env.*)",
      "Write(path:.env)",
      "Write(path:.env.*)",
      "Bash(cat .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(echo * > .env*)",
      "Bash(cp * .env*)",
      "Bash(mv * .env*)"
    ]
  }
}
